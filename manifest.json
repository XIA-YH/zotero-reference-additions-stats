{
  "manifest_version": 2,
  "name": "Reference Additions Stats",
  "version": "0.5.4",
  "description": "Open a Zotero-native dashboard for references added over time in Zotero 7, 8, and 9.",
  "author": "konstellation",
  "homepage_url": "https://example.com",
  "icons": {
    "48": "icon.svg",
    "96": "icon.svg"
  },
  "applications": {
    "zotero": {
      "id": "monthly-stats@konstellation.local",
      "update_url": "https://example.com/reference-additions-stats/updates.json",
      "strict_min_version": "6.999",
      "strict_max_version": "9.0.*"
    }
  }
}
